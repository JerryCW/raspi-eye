  <diagram name="System Architecture" id="raspi-eye-arch">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <!-- ===== Device Side (Left) ===== -->
        <mxCell id="device-group" value="Raspberry Pi 5 (Linux aarch64)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;verticalAlign=top;fontStyle=1;fontSize=14;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="520" height="520" as="geometry" />
        </mxCell>
        <!-- Camera -->
        <mxCell id="camera" value="🎥 IMX678&#xa;USB Camera&#xa;/dev/IMX678" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="70" y="90" width="120" height="70" as="geometry" />
        </mxCell>
        <!-- smart-camera C++ -->
        <mxCell id="smart-camera" value="smart-camera (C++17)&#xa;GStreamer Pipeline&#xa;v4l2src → jpegdec → x264enc" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="230" y="90" width="200" height="70" as="geometry" />
        </mxCell>
        <!-- GStreamer tee -->
        <mxCell id="tee" value="tee (raw_t)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="290" y="190" width="80" height="50" as="geometry" />
        </mxCell>
        <!-- Encoder -->
        <mxCell id="encoder" value="x264enc&#xa;(threads=2)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="140" y="270" width="100" height="40" as="geometry" />
        </mxCell>
        <!-- h264 tee -->
        <mxCell id="h264tee" value="tee (h264_t)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="150" y="340" width="80" height="50" as="geometry" />
        </mxCell>
        <!-- AI branch -->
        <mxCell id="ai-branch" value="videoconvert&#xa;(BGR)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="380" y="270" width="100" height="40" as="geometry" />
        </mxCell>
        <!-- FrameExporter -->
        <mxCell id="frame-exporter" value="FrameExporter&#xa;(shm + unix socket)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="370" y="340" width="120" height="40" as="geometry" />
        </mxCell>
        <!-- Activity Detector Python -->
        <mxCell id="detector" value="🐍 activity-detector&#xa;YOLO → 检测 → S3 上传" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="340" y="420" width="190" height="50" as="geometry" />
        </mxCell>
        <!-- Arrows: Device internal -->
        <mxCell id="e1" edge="1" source="camera" target="smart-camera" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" edge="1" source="smart-camera" target="tee" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" value="编码链" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="tee" target="encoder" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" edge="1" source="encoder" target="h264tee" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" value="AI 分支" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="tee" target="ai-branch" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" edge="1" source="ai-branch" target="frame-exporter" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7" value="IPC" edge="1" source="frame-exporter" target="detector" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- ===== AWS Cloud (Right) ===== -->
        <mxCell id="cloud-group" value="AWS Cloud (ap-southeast-1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;verticalAlign=top;fontStyle=1;fontSize=14;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="640" y="40" width="920" height="520" as="geometry" />
        </mxCell>
        <!-- KVS Stream -->
        <mxCell id="kvs" value="📹 KVS Stream&#xa;RaspiEyeAlphaStream&#xa;(云录像回放)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="680" y="100" width="160" height="60" as="geometry" />
        </mxCell>
        <!-- KVS WebRTC Channel -->
        <mxCell id="webrtc" value="📡 KVS WebRTC&#xa;RaspiEyeAlphaChannel&#xa;(实时预览)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="680" y="190" width="160" height="60" as="geometry" />
        </mxCell>
        <!-- IoT Core -->
        <mxCell id="iot" value="🔐 IoT Core&#xa;X.509 mTLS&#xa;STS 临时凭证" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="680" y="280" width="160" height="60" as="geometry" />
        </mxCell>
        <!-- S3 -->
        <mxCell id="s3" value="📦 S3&#xa;smart-camera-captures&#xa;截图 + event.json" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="920" y="100" width="170" height="60" as="geometry" />
        </mxCell>
        <!-- Lambda -->
        <mxCell id="lambda" value="⚡ Lambda&#xa;fn-cloud-verifier&#xa;S3 触发 → 验证 → DynamoDB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="920" y="200" width="170" height="60" as="geometry" />
        </mxCell>
        <!-- SageMaker -->
        <mxCell id="sagemaker" value="🧠 SageMaker&#xa;DINOv2 Fine-tuned&#xa;39 种鸟类分类" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1160" y="200" width="160" height="60" as="geometry" />
        </mxCell>
        <!-- DynamoDB -->
        <mxCell id="dynamodb" value="📊 DynamoDB&#xa;raspi-eye-events&#xa;PK=device_id SK=start_time" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="920" y="310" width="170" height="60" as="geometry" />
        </mxCell>
        <!-- Cognito -->
        <mxCell id="cognito" value="👤 Cognito&#xa;用户认证" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1160" y="100" width="120" height="50" as="geometry" />
        </mxCell>
        <!-- ECS Viewer -->
        <mxCell id="ecs" value="🌐 ECS (Viewer)&#xa;raspi-eye-web&#xa;Vite + Node.js + ffmpeg" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1140" y="380" width="180" height="60" as="geometry" />
        </mxCell>
        <!-- Browser -->
        <mxCell id="browser" value="🖥️ 浏览器&#xa;Chrome / Safari" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1160" y="500" width="140" height="50" as="geometry" />
        </mxCell>
        <!-- ===== Cross-boundary arrows ===== -->
        <!-- Device → KVS (kvssink) -->
        <mxCell id="e-kvs" value="H.264 (avc)" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#b85450;" edge="1" source="h264tee" target="kvs" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Device → WebRTC -->
        <mxCell id="e-webrtc" value="H.264 (byte-stream)" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#b85450;" edge="1" source="h264tee" target="webrtc" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Device → IoT -->
        <mxCell id="e-iot" value="mTLS" style="dashed=1;strokeColor=#999;" edge="1" source="smart-camera" target="iot" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Detector → S3 -->
        <mxCell id="e-s3" value="截图 + event.json" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#82b366;" edge="1" source="detector" target="s3" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- S3 → Lambda (trigger) -->
        <mxCell id="e-s3-lambda" value="S3 Event" style="strokeColor=#d6b656;" edge="1" source="s3" target="lambda" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Lambda → SageMaker -->
        <mxCell id="e-lambda-sm" value="推理请求" style="strokeColor=#d6b656;" edge="1" source="lambda" target="sagemaker" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Lambda → DynamoDB -->
        <mxCell id="e-lambda-ddb" value="写入事件" style="strokeColor=#d6b656;" edge="1" source="lambda" target="dynamodb" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- ECS → DynamoDB -->
        <mxCell id="e-ecs-ddb" value="查询事件" style="strokeColor=#82b366;" edge="1" source="ecs" target="dynamodb" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- ECS → KVS (GetClip) -->
        <mxCell id="e-ecs-kvs" value="GetClip / HLS" style="strokeColor=#82b366;dashed=1;" edge="1" source="ecs" target="kvs" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- ECS → S3 (thumbnails) -->
        <mxCell id="e-ecs-s3" value="presigned URL" style="strokeColor=#82b366;dashed=1;" edge="1" source="ecs" target="s3" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- ECS → Cognito -->
        <mxCell id="e-ecs-cognito" value="JWT 验证" style="strokeColor=#82b366;dashed=1;" edge="1" source="ecs" target="cognito" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Browser → ECS -->
        <mxCell id="e-browser-ecs" value="HTTPS" style="strokeColor=#666;" edge="1" source="browser" target="ecs" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Browser → WebRTC (direct) -->
        <mxCell id="e-browser-webrtc" value="WebRTC (P2P)" style="strokeColor=#6c8ebf;dashed=1;" edge="1" source="browser" target="webrtc" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
