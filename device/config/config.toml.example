# AWS IoT configuration for raspi-eye device
# This file is a template for reference only.
# Actual config.toml is auto-generated by: scripts/provision-device.sh
# Do NOT edit config.toml manually; re-run the provisioning script instead.

[aws]
thing_name = "<your-thing-name>"
credential_endpoint = "<your-account-id>.credentials.iot.<region>.amazonaws.com"
role_alias = "<your-project-name>RoleAlias"
cert_path = "device/certs/device-cert.pem"
key_path = "device/certs/device-private.key"
ca_path = "device/certs/root-ca.pem"

# KVS (Kinesis Video Streams) configuration
# stream_name: KVS stream name (must be pre-created via AWS CLI or IaC)
# aws_region: AWS region where the KVS stream is located
[kvs]
stream_name = "<your-kvs-stream-name>"
aws_region = "<your-aws-region>"
